rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profile: Access restricted by Document ID (User's UID)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Entries: Access restricted by the 'uid' field inside the document
    match /entries/{entryId} {
      // For reading, updating, or deleting existing entries
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      
      // For creating new entries (ensures they can only save data under their own UID)
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }
  }
}